# Gateway serves diary at /mfe/diary. Omit or leave empty to default to /mfe/diary in next.config.
NEXT_PUBLIC_DIARY_BASE_PATH=/mfe/diary
# Set to "true" when developing through the gateway (localhost:3000) so assets and
# HMR go through the gateway and hot reload works. Omit or "false" for standalone dev.
# NEXT_PUBLIC_VIA_GATEWAY=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:4281
