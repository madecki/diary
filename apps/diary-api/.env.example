# =============================================================================
# Diary API — local development (copy to .env)
# =============================================================================
DATABASE_URL=postgresql://diary:diary@localhost:54320/diary
PORT=4281

# Must match DIARY_SERVICE_TOKEN in gateway/.env (≥32 chars)
GATEWAY_SERVICE_TOKEN=local-dev-omniradon-service-token-min-32-chars-required

# Settings API (insights user context; same GATEWAY_SERVICE_TOKEN as diary)
SETTINGS_SERVICE_URL=http://localhost:4381

# LLM / insights
LLM_SERVICE_URL=http://localhost:4583
DIARY_INSIGHT_MODEL=qwen2.5:14b
INSIGHT_DEBOUNCE_MS=5000
# Optional override for insight system prompt files (default: monorepo prompts/)
# DIARY_PROMPTS_DIR=/absolute/path/to/prompts
