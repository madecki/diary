DATABASE_URL=postgresql://diary:diary@localhost:54320/diary
PORT=4281

# ── Service-to-service trust ────────────────────────────────────────────────
# GATEWAY_SERVICE_TOKEN must match DIARY_SERVICE_TOKEN in the gateway.
# All requests without a valid token are rejected — diary-api cannot be called
# directly without it, preventing x-user-id header forgery.
#
# Generate with: openssl rand -hex 32
GATEWAY_SERVICE_TOKEN=
