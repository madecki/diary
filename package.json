{
  "name": "diary",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "docker compose -f infra/docker-compose.yml up -d && pnpm db:migrate:deploy && pnpm dev",
    "e2e": "pnpm --filter diary-e2e e2e",
    "e2e:ui": "pnpm --filter diary-e2e e2e:ui",
    "predev": "lsof -ti :4280 -ti :4281 2>/dev/null | xargs kill -9 2>/dev/null || true",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @diary/database db:generate",
    "db:migrate": "pnpm --filter @diary/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @diary/database db:migrate:deploy",
    "db:seed": "pnpm --filter @diary/database db:seed",
    "db:studio": "pnpm --filter @diary/database db:studio",
    "db:backup": "pnpm --filter @diary/database db:backup",
    "db:restore:backups": "pnpm --filter @diary/database db:restore:backups",
    "clean": "turbo clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@nestjs/core",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}
