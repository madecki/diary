generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntryType {
  checkin
  note
}

enum CheckInType {
  morning
  evening
}

enum RefType {
  difficult
  neutral
  pleasant
}

model Entry {
  id          String      @id
  type        EntryType
  localDate   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Note fields (null for check-ins)
  title       String?
  contentJson Json?
  plainText   String?
  wordCount   Int?
  noteFolderId String?
  noteFolder   NoteFolder? @relation(fields: [noteFolderId], references: [id], onDelete: SetNull)

  // Check-in fields (null / empty for notes)
  mood                  Int?
  emotions              String[]     @default([])
  triggers              String[]     @default([])
  checkInType           CheckInType?
  whatImGratefulFor     String[]     @default([])
  whatWouldMakeDayGreat String[]     @default([])
  dailyAffirmation      String?
  highlightsOfTheDay    String[]     @default([])
  whatDidILearnToday    String?

  @@index([type])
  @@index([createdAt])
  @@index([localDate])
  @@index([noteFolderId])
  @@map("entries")
}

model NoteFolder {
  id        String      @id
  name      String
  path      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  parentId  String?
  parent    NoteFolder? @relation("NoteFolderParent", fields: [parentId], references: [id], onDelete: Cascade)
  children  NoteFolder[] @relation("NoteFolderParent")
  notes     Entry[]

  @@index([parentId])
  @@map("note_folders")
}

model Emotion {
  id        String   @id
  label     String   @unique
  type      RefType
  createdAt DateTime @default(now())

  @@map("emotions")
}

model Trigger {
  id        String   @id
  label     String   @unique
  type      RefType
  createdAt DateTime @default(now())

  @@map("triggers")
}

model OutboxEvent {
  globalSequence       BigInt    @id @default(autoincrement())
  eventId              String    @unique
  eventName            String
  eventVersion         Int
  occurredAt           DateTime
  aggregateId          String
  aggregateType        String
  aggregateVersion     Int
  actorUserId          String
  payload              Json
  publishedAt          DateTime?
  publishAttempts      Int       @default(0)
  lastPublishError     String?
  lastPublishAttemptAt DateTime?

  @@index([aggregateId, aggregateVersion])
  @@index([publishedAt, globalSequence])
  @@index([eventName, occurredAt])
  @@map("outbox_events")
}
