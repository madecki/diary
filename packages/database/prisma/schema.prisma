generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntryType {
  checkin
  short_note
}

enum CheckInType {
  morning
  evening
}

enum RefType {
  difficult
  neutral
  pleasant
}

model Entry {
  id          String      @id
  type        EntryType
  localDate   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Short note fields (null for check-ins)
  title       String?
  contentJson Json?
  plainText   String?
  wordCount   Int?

  // Check-in fields (null / empty for short notes)
  mood                  Int?
  emotions              String[]     @default([])
  triggers              String[]     @default([])
  checkInType           CheckInType?
  whatImGratefulFor     String[]     @default([])
  whatWouldMakeDayGreat String[]     @default([])
  dailyAffirmation      String?
  highlightsOfTheDay    String[]     @default([])
  whatDidILearnToday    String?

  @@index([type])
  @@index([createdAt])
  @@index([localDate])
  @@map("entries")
}

model Emotion {
  id        String   @id
  label     String   @unique
  type      RefType
  createdAt DateTime @default(now())

  @@map("emotions")
}

model Trigger {
  id        String   @id
  label     String   @unique
  type      RefType
  createdAt DateTime @default(now())

  @@map("triggers")
}

model OutboxEvent {
  globalSequence       BigInt    @id @default(autoincrement())
  eventId              String    @unique
  eventName            String
  eventVersion         Int
  occurredAt           DateTime
  aggregateId          String
  aggregateType        String
  aggregateVersion     Int
  actorUserId          String
  payload              Json
  publishedAt          DateTime?
  publishAttempts      Int       @default(0)
  lastPublishError     String?
  lastPublishAttemptAt DateTime?

  @@index([aggregateId, aggregateVersion])
  @@index([publishedAt, globalSequence])
  @@index([eventName, occurredAt])
  @@map("outbox_events")
}
