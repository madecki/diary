generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntryType {
  checkin
}

enum CheckInType {
  morning
  evening
  basic
}

enum RefType {
  difficult
  neutral
  pleasant
}

enum Permission {
  read
  write
  both
}

model Entry {
  id            String      @id
  type          EntryType
  localDateTime String      // YYYY-MM-DDTHH:mm (date + time for ordering/same-day entries)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Owner — null means legacy entry (pre-auth), visible to any authenticated user
  ownerId String?

  // Rich note body (BlockNote JSON) — optional on morning/evening; required for basic check-ins
  contentJson Json?
  plainText   String?
  wordCount   Int?
  accessList  AccessList[]

  // Check-in fields
  mood                  Int?
  emotions              String[]     @default([])
  triggers              String[]     @default([])
  checkInType           CheckInType?
  whatImGratefulFor     String[]     @default([])
  whatWouldMakeDayGreat String[]     @default([])
  dailyAffirmation      String?
  highlightsOfTheDay    String[]     @default([])
  whatDidILearnToday    String?

  @@index([type])
  @@index([createdAt])
  @@index([localDateTime])
  @@index([ownerId])
  @@map("entries")
}

model AccessList {
  id         String     @id
  entryId    String
  userId     String
  permission Permission
  createdAt  DateTime   @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([entryId])
  @@index([userId])
  @@map("access_list")
}

model Emotion {
  id        String   @id
  ownerId   String
  label     String
  type      RefType
  createdAt DateTime @default(now())

  @@unique([ownerId, label])
  @@index([ownerId])
  @@map("emotions")
}

model Trigger {
  id        String   @id
  ownerId   String
  label     String
  type      RefType
  createdAt DateTime @default(now())

  @@unique([ownerId, label])
  @@index([ownerId])
  @@map("triggers")
}

model OutboxEvent {
  globalSequence       BigInt    @id @default(autoincrement())
  eventId              String    @unique
  eventName            String
  eventVersion         Int
  occurredAt           DateTime
  aggregateId          String
  aggregateType        String
  aggregateVersion     Int
  actorUserId          String
  payload              Json
  publishedAt          DateTime?
  publishAttempts      Int       @default(0)
  lastPublishError     String?
  lastPublishAttemptAt DateTime?

  @@index([aggregateId, aggregateVersion])
  @@index([publishedAt, globalSequence])
  @@index([eventName, occurredAt])
  @@map("outbox_events")
}

model InsightRecord {
  id          String    @id
  ownerId     String
  type        String // "daily" | "weekly"
  date        String // ISO date YYYY-MM-DD
  jobId       String
  status      String    @default("pending") // pending | processing | completed | failed | cancelled
  content     String?
  promptHash  String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([ownerId, type, date])
  @@index([status])
  @@index([jobId])
  @@index([ownerId])
  @@map("insight_records")
}
