generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntryType {
  checkin
  note
}

enum CheckInType {
  morning
  evening
}

enum RefType {
  difficult
  neutral
  pleasant
}

enum Permission {
  read
  write
  both
}

model Entry {
  id             String      @id
  type           EntryType
  localDateTime  String      // YYYY-MM-DDTHH:mm (date + time for ordering/same-day entries)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Owner — null means legacy entry (pre-auth), visible to any authenticated user
  ownerId     String?

  // Note fields (null for check-ins)
  title       String?
  contentJson Json?
  plainText   String?
  wordCount   Int?
  noteFolderId String?
  noteFolder   NoteFolder? @relation(fields: [noteFolderId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags         Tag[]       @relation("EntryTags")
  accessList   AccessList[]

  // Check-in fields (null / empty for notes)
  mood                  Int?
  emotions              String[]     @default([])
  triggers              String[]     @default([])
  checkInType           CheckInType?
  whatImGratefulFor     String[]     @default([])
  whatWouldMakeDayGreat String[]     @default([])
  dailyAffirmation      String?
  highlightsOfTheDay    String[]     @default([])
  whatDidILearnToday    String?

  @@index([type])
  @@index([createdAt])
  @@index([localDateTime])
  @@index([noteFolderId])
  @@index([projectId])
  @@index([ownerId])
  @@map("entries")
}

model Project {
  id          String   @id
  ownerId     String
  name        String
  description String?
  color       String   @default("primary")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  entries     Entry[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@map("projects")
}

model Tag {
  id        String   @id
  ownerId   String
  name      String
  createdAt DateTime @default(now())
  entries   Entry[]  @relation("EntryTags")

  @@unique([ownerId, name])
  @@index([ownerId])
  @@map("tags")
}

model NoteFolder {
  id        String      @id
  name      String
  path      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  parentId  String?
  parent    NoteFolder? @relation("NoteFolderParent", fields: [parentId], references: [id], onDelete: Cascade)
  children  NoteFolder[] @relation("NoteFolderParent")
  notes     Entry[]

  @@index([parentId])
  @@map("note_folders")
}

model Emotion {
  id        String   @id
  ownerId   String
  label     String
  type      RefType
  createdAt DateTime @default(now())

  @@unique([ownerId, label])
  @@index([ownerId])
  @@map("emotions")
}

model Trigger {
  id        String   @id
  ownerId   String
  label     String
  type      RefType
  createdAt DateTime @default(now())

  @@unique([ownerId, label])
  @@index([ownerId])
  @@map("triggers")
}

model AccessList {
  id         String     @id
  entryId    String
  userId     String
  permission Permission
  createdAt  DateTime   @default(now())

  entry      Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([entryId])
  @@index([userId])
  @@map("access_list")
}

model OutboxEvent {
  globalSequence       BigInt    @id @default(autoincrement())
  eventId              String    @unique
  eventName            String
  eventVersion         Int
  occurredAt           DateTime
  aggregateId          String
  aggregateType        String
  aggregateVersion     Int
  actorUserId          String
  payload              Json
  publishedAt          DateTime?
  publishAttempts      Int       @default(0)
  lastPublishError     String?
  lastPublishAttemptAt DateTime?

  @@index([aggregateId, aggregateVersion])
  @@index([publishedAt, globalSequence])
  @@index([eventName, occurredAt])
  @@map("outbox_events")
}
